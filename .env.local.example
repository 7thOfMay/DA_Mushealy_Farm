# ═══════════════════════════════════════════════════════════════
# NôngTech Smart Farm - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# When DB variables are NOT set, the app runs in demo mode
# with mock data stored in localStorage.
# ═══════════════════════════════════════════════════════════════

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_farm

# --- App ---
# NEXT_PUBLIC_USE_DEMO_DATA=true
